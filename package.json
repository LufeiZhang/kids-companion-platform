{
  "name": "kids-companion-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "server"
  ],
  "scripts": {
    "postinstall": "tsc -p packages/types/tsconfig.json",
    "dev": "concurrently -n server,teacher,student,admin -c blue,cyan,magenta,yellow \"npm run dev -w @companion/server\" \"npm run dev -w @companion/teacher-web\" \"npm run dev -w @companion/student-web\" \"npm run dev -w @companion/admin-web\"",
    "dev:server": "npm run dev -w @companion/server",
    "dev:teacher": "npm run dev -w @companion/teacher-web",
    "dev:student": "npm run dev -w @companion/student-web",
    "dev:admin": "npm run dev -w @companion/admin-web",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:generate": "npm run db:generate -w @companion/server",
    "db:migrate": "npm run db:migrate -w @companion/server",
    "db:seed": "npm run db:seed -w @companion/server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
